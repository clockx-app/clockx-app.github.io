<svg xmlns="http://www.w3.org/2000/svg" width="180" height="180" viewBox="0 0 180 180">
  <defs>
    <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#0B5FFF"/>
      <stop offset="100%" stop-color="#0A66FF"/>
    </linearGradient>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="6" stdDeviation="8" flood-color="#0A3EA3" flood-opacity="0.35"/>
    </filter>
  </defs>
  <!-- Solid background to avoid transparency on iOS -->
  <rect x="0" y="0" width="180" height="180" fill="#ffffff"/>
  <!-- App icon tile -->
  <g filter="url(#shadow)">
    <rect x="20" y="20" width="140" height="140" rx="32" ry="32" fill="#f4f8ff"/>
  </g>
  <!-- Clock emblem -->
  <g transform="translate(90,90)">
    <circle cx="0" cy="0" r="54" fill="url(#g)"/>
    <!-- hour hand -->
    <line x1="0" y1="0" x2="0" y2="-26" stroke="#ffffff" stroke-width="6" stroke-linecap="round"/>
    <!-- minute hand -->
    <line x1="0" y1="0" x2="28" y2="16" stroke="#ffffff" stroke-width="6" stroke-linecap="round"/>
    <circle cx="0" cy="0" r="5" fill="#ffffff"/>
  </g>
</svg>
